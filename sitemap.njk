---
# Emitted into public/ because the Vite build step discards non-HTML Eleventy
# output; Vite copies public/ contents verbatim to the site root, so this file
# is ultimately served at /sitemap.xml.
permalink: /public/sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {# Homepage #}
  <url>
    <loc>https://aliramadhan.me/</loc>
    <lastmod>{{ buildDate | dateDisplay }}</lastmod>
  </url>

  {# Blog posts collection #}
  {%- for post in collections.posts %}
  <url>
    <loc>https://aliramadhan.me{{ post.url }}</loc>
    <lastmod>{{ post.date | dateDisplay }}</lastmod>
  </url>
  {%- endfor %}

  {# Project Euler collection (regular + bonus problems) #}
  {%- for problem in collections.allEuler %}
  <url>
    <loc>https://aliramadhan.me{{ problem.url }}</loc>
    <lastmod>{{ problem.date | dateDisplay }}</lastmod>
  </url>
  {%- endfor %}
</urlset>
